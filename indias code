#include <iostream>
#include <vector>
using namespace std;

#define NUM_CLASSES 4

// Basic block structure
struct block {
    size_t size;
    bool free;
    block* next;
};

// Global free list (for First Fit & Best Fit)
block* free_list = nullptr;

// Segregated free lists
block* free_lists[NUM_CLASSES] = {nullptr, nullptr, nullptr, nullptr};


// =======================
// FIRST FIT
// =======================
block* first_fit(size_t size) {
    block* curr = free_list;

    while (curr != nullptr) {
        if (curr->free && curr->size >= size) {
            return curr;
        }
        curr = curr->next;
    }

    return nullptr;
}


// =======================
// BEST FIT
// =======================
block* best_fit(size_t size) {
    block* curr = free_list;
    block* best = nullptr;

    while (curr != nullptr) {
        if (curr->free && curr->size >= size) {
            if (best == nullptr || curr->size < best->size) {
                best = curr;
            }
        }
        curr = curr->next;
    }

    return best;
}


// =======================
// SEGREGATED LIST HELPERS
// =======================
int get_index(size_t size) {
    if (size <= 16) return 0;
    else if (size <= 32) return 1;
    else if (size <= 64) return 2;
    else return 3;
}


// =======================
// SEGREGATED FIT
// =======================
block* segregated_fit(size_t size) {
    int index = get_index(size);

    block* curr = free_lists[index];

    while (curr != nullptr) {
        if (curr->free && curr->size >= size) {
            return curr;
        }
        curr = curr->next;
    }

    return nullptr;
}


// =======================
// ADD BLOCK TO FREE LIST
// =======================
void add_to_free_list(block*& list, block* new_block) {
    new_block->next = list;
    list = new_block;
}


// =======================
// MAIN WITH USER INPUT
// =======================
int main() {
    int n;
    cout << "Enter number of free memory blocks: ";
    cin >> n;

    // Use vector to safely store blocks
    vector<block> blocks(n);

    // Input block sizes
    for (int i = 0; i < n; i++) {
        cout << "Enter size of block " << i + 1 << ": ";
        cin >> blocks[i].size;

        blocks[i].free = true;
        blocks[i].next = nullptr;

        // Add to general free list
        add_to_free_list(free_list, &blocks[i]);

        // Add to segregated list
        int index = get_index(blocks[i].size);
        add_to_free_list(free_lists[index], &blocks[i]);
    }

    size_t request;
    cout << "\nEnter allocation request size: ";
    cin >> request;

    // Run strategies
    block* result1 = first_fit(request);
    block* result2 = best_fit(request);
    block* result3 = segregated_fit(request);

    cout << "\n--- Results ---\n";

    if (result1)
        cout << "First Fit selected block of size: " << result1->size << endl;
    else
        cout << "First Fit: No suitable block found\n";

    if (result2)
        cout << "Best Fit selected block of size: " << result2->size << endl;
    else
        cout << "Best Fit: No suitable block found\n";

    if (result3)
        cout << "Segregated Fit selected block of size: " << result3->size << endl;
    else
        cout << "Segregated Fit: No suitable block found\n";

    return 0;
}
