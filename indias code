#include <iostream>
#include <vector>
#include <cstddef>
using namespace std;

#define ALIGNMENT 8
#define NUM_CLASSES 4

size_t align(size_t size) {
    return (size + (ALIGNMENT - 1)) & ~(ALIGNMENT - 1);
}

struct Block {
    size_t size;
    bool free;

    Block* next_phys;
    Block* prev_phys;

    Block* next_free;   // for global free list
    Block* next_seg;    // for segregated lists
};

class MemoryAllocator {
private:
    vector<char> heap;

    Block* head;
    Block* free_list;
    Block* segregated[NUM_CLASSES];

public:
    MemoryAllocator(size_t heap_size) {
        heap.resize(heap_size);

        head = reinterpret_cast<Block*>(&heap[0]);

        head->size = heap_size - sizeof(Block);
        head->free = true;

        head->next_phys = nullptr;
        head->prev_phys = nullptr;
        head->next_free = nullptr;
        head->next_seg = nullptr;

        free_list = head;

        for (int i = 0; i < NUM_CLASSES; i++)
            segregated[i] = nullptr;

        insert_free(head);
    }

    int get_index(size_t size) {
        if (size <= 32) return 0;
        else if (size <= 64) return 1;
        else if (size <= 128) return 2;
        else return 3;
    }

    void insert_free(Block* block) {
        // global free list
        block->next_free = free_list;
        free_list = block;

        // segregated list
        int idx = get_index(block->size);
        block->next_seg = segregated[idx];
        segregated[idx] = block;
    }

    void remove_free(Block* block) {
        // remove from global free list
        Block* curr = free_list;
        Block* prev = nullptr;

        while (curr) {
            if (curr == block) {
                if (prev) prev->next_free = curr->next_free;
                else free_list = curr->next_free;
                break;
            }
            prev = curr;
            curr = curr->next_free;
        }

        // remove from segregated list
        int idx = get_index(block->size);
        curr = segregated[idx];
        prev = nullptr;

        while (curr) {
            if (curr == block) {
                if (prev) prev->next_seg = curr->next_seg;
                else segregated[idx] = curr->next_seg;
                break;
            }
            prev = curr;
            curr = curr->next_seg;
        }
    }

    void split(Block* block, size_t size) {
        if (block->size >= size + sizeof(Block) + ALIGNMENT) {
            Block* new_block = reinterpret_cast<Block*>(
                reinterpret_cast<char*>(block) + sizeof(Block) + size
            );

            new_block->size = block->size - size - sizeof(Block);
            new_block->free = true;

            new_block->next_phys = block->next_phys;
            new_block->prev_phys = block;

            if (block->next_phys)
                block->next_phys->prev_phys = new_block;

            block->next_phys = new_block;

            block->size = size;

            insert_free(new_block);
        }
    }

    void coalesce(Block* block) {
        if (block->next_phys && block->next_phys->free) {
            remove_free(block->next_phys);

            block->size += sizeof(Block) + block->next_phys->size;
            block->next_phys = block->next_phys->next_phys;

            if (block->next_phys)
                block->next_phys->prev_phys = block;
        }

        if (block->prev_phys && block->prev_phys->free) {
            Block* prev = block->prev_phys;

            remove_free(prev);

            prev->size += sizeof(Block) + block->size;
            prev->next_phys = block->next_phys;

            if (block->next_phys)
                block->next_phys->prev_phys = prev;

            block = prev;
        }

        insert_free(block);
    }

    Block* first_fit(size_t size) {
        Block* curr = free_list;
        while (curr) {
            if (curr->free && curr->size >= size)
                return curr;
            curr = curr->next_free;
        }
        return nullptr;
    }

    Block* best_fit(size_t size) {
        Block* curr = free_list;
        Block* best = nullptr;

        while (curr) {
            if (curr->free && curr->size >= size) {
                if (!best || curr->size < best->size)
                    best = curr;
            }
            curr = curr->next_free;
        }
        return best;
    }

    Block* segregated_fit(size_t size) {
        int idx = get_index(size);

        for (int i = idx; i < NUM_CLASSES; i++) {
            Block* curr = segregated[i];
            while (curr) {
                if (curr->free && curr->size >= size)
                    return curr;
                curr = curr->next_seg;
            }
        }
        return nullptr;
    }

    void* allocate(size_t size, int strategy) {
        size = align(size);

        Block* block = nullptr;

        if (strategy == 1) block = first_fit(size);
        else if (strategy == 2) block = best_fit(size);
        else if (strategy == 3) block = segregated_fit(size);

        if (!block) return nullptr;

        remove_free(block);

        split(block, size);

        block->free = false;

        return reinterpret_cast<char*>(block) + sizeof(Block);
    }

    void deallocate(void* ptr) {
        if (!ptr) return;

        Block* block = reinterpret_cast<Block*>(
            reinterpret_cast<char*>(ptr) - sizeof(Block)
        );

        block->free = true;

        coalesce(block);
    }
};

int main() {
    size_t heap_size;
    cout << "Enter heap size: ";
    cin >> heap_size;

    MemoryAllocator allocator(heap_size);

    int strategy;
    cout << "Strategy (1=First Fit, 2=Best Fit, 3=Segregated): ";
    cin >> strategy;

    size_t request;
    cout << "Enter allocation size: ";
    cin >> request;

    void* ptr = allocator.allocate(request, strategy);

    if (ptr)
        cout << "Allocation successful\n";
    else
        cout << "Allocation failed\n";

    cout << "Free memory? (1=yes): ";
    int choice;
    cin >> choice;

    if (choice == 1) {
        allocator.deallocate(ptr);
        cout << "Memory freed\n";
    }

    return 0;
}
